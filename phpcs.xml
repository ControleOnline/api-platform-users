<?xml version="1.0"?>
<ruleset name="ControleOnline Users">
    <description>Regras minimas para estabilizar a analise automatica do modulo.</description>

    <arg name="basepath" value="."/>
    <arg name="colors"/>
    <arg name="extensions" value="php"/>
    <arg name="parallel" value="4"/>

    <file>src</file>

    <exclude-pattern>vendor/*</exclude-pattern>
    <exclude-pattern>migrations/*</exclude-pattern>

    <rule ref="PSR12"/>
</ruleset>
